# 1. 忽略 Python 编译产生的垃圾文件
__pycache__/
*.py[cod]
*$py.class

# 2. 忽略虚拟环境 (非常重要！)
# 你的环境名叫 venv，所以这行必须有
venv/
env/
.venv/
.env

# 3. 忽略 PyInstaller 打包产物
# 你的 exe 在 dist 里，中间产物在 build 里，都不需要上传
build/
dist/
*.spec

# 4. 忽略 IDE 配置文件 (看你用什么编辑器)
.idea/
.vscode/
*.swp

# 5. 忽略操作系统生成的文件
.DS_Store
Thumbs.db

# 6. 忽略本地的敏感配置
# config.toml 包含凭证(腾讯文档 access_token、Anthropic API key 等),不进 git
# 模板见 config.example.toml(已提交)
config.toml

*.mid
piano_roll_test.py
asset/ide_config.json
那些你很冒险的梦_Beat.csv
怪物_Structure.csv

# Local-only reference codebase (not part of this project)
GenericAgent/

# Node / Electron / Vite
node_modules/
app/dist/
app/dist-electron/
app/tsconfig.*.tsbuildinfo
*.log

# 7. 腾讯文档表数据 disk cache (开发期手动管理, 不进 git)
cache/

# 8. 本地参考资料(不进 git)
doc/v2_验收清单.md
doc/音乐学院数据要求.md

# 9. 本地临时测试沙盒
tmp/
