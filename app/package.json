{
  "name": "audio-qc-app",
  "version": "0.1.0",
  "description": "Audio QC desktop frontend (Electron + React + Vite)",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "postinstall": "electron-builder install-app-deps",
    "build": "npm run build:app && npm run package",
    "build:app": "tsc -b && vite build",
    "runtime:prepare": "node ../scripts/prepare-runtime.mjs",
    "runtime:verify": "node ../scripts/verify-package.mjs ../packaging/staging",
    "assets:mac": "node ../scripts/render-dmg-background.mjs",
    "package": "node ../scripts/package-host.mjs",
    "package:win": "npm run runtime:prepare && npm run runtime:verify && electron-builder --config electron-builder.yml --win zip --x64",
    "package:mac:x64": "npm run runtime:prepare && npm run runtime:verify && npm run assets:mac && electron-builder --config electron-builder.yml --mac dmg zip --x64",
    "package:mac:arm64": "npm run runtime:prepare && npm run runtime:verify && npm run assets:mac && electron-builder --config electron-builder.yml --mac dmg zip --arm64",
    "package:verify": "node ../scripts/verify-package.mjs",
    "preview": "vite preview",
    "electron:dev": "vite",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.9.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "tar": "^7.5.20",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.5.2",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^3.6.0",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  }
}
